# Public app URL used by PayPal return/cancel URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase client config from Firebase Console > Project settings > Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin service account values for Vercel serverless API routes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# PayPal Subscriptions.
# Use "sandbox" while testing and "live" only after the PayPal plan/webhook are live.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_ID=
PAYPAL_WEBHOOK_ID=

# Browser PayPal SDK client ID. Usually the same value as PAYPAL_CLIENT_ID.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
